# ── Secrets / personal data — NEVER commit ───────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets.*
credentials*.json
service-account*.json
*token*.json

# ── Runtime data & outputs (file-storage mode; regenerated by main.py) ─
/data/
/webmap/
/prompts_out/
*.parquet
*.geojson

# ── Generated analysis outputs (re-created by analysis/ranking_review.py) ─
/analysis/*.csv

# ── Heavy artifacts: ML models, archives, raw geo ────────────────────
*.joblib
*.pkl
*.h5
*.zip
*.gz
*.tar
*.7z
*.gpkg
*.shp
*.shx
*.dbf
*.prj
*.tif
*.tiff

# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
build/
dist/

# ── Logs ─────────────────────────────────────────────────────────────
*.log
airflow/logs/

