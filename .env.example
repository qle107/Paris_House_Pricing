# Database
REI_PG_HOST=localhost
REI_PG_PORT=5432
REI_PG_DB=rei
REI_PG_USER=rei
REI_PG_PASSWORD=change_me

# INSEE (Melodi is keyless; SIRENE needs an app key from portail-api.insee.fr)
REI_INSEE_SIRENE_KEY=

# AI research agent
# manual  — export prompt, paste JSON answer, ingest (no model install)
# ollama  — local model (https://ollama.com)
# openai  — API
REI_LLM_PROVIDER=manual
REI_OLLAMA_BASE_URL=http://localhost:11434
REI_OLLAMA_CHAT_MODEL=llama3.1:8b
REI_EMBED_BACKEND=sentence_transformers
REI_EMBED_MODEL=intfloat/multilingual-e5-base
REI_EMBED_DIM=768

# Optional OpenAI (set REI_LLM_PROVIDER=openai and REI_EMBED_BACKEND=openai)
OPENAI_API_KEY=
REI_OPENAI_CHAT_MODEL=gpt-4o
REI_OPENAI_EMBED_MODEL=text-embedding-3-small

# Runtime
REI_DATA_DIR=/data/rei
REI_HTTP_MAX_RPS=5
REI_LOG_LEVEL=INFO
